# Only external API used by the simplified Fixate app.
# Leave OPENAI_API_KEY blank to run deterministic local demo agents.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_IMAGE_MODEL=gpt-image-1

# Optional: where screenshots, heatmaps, and variant images are stored.
# Blank means your system temp directory.
FIXATE_JOBS_DIR=
